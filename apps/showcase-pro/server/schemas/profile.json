{
  "version": "1.0",
  "screen": "profile",
  "schema": {
    "type": "container",
    "props": {
      "padding": "lg"
    },
    "children": [
      {
        "type": "vstack",
        "props": {
          "spacing": "lg",
          "align": "center"
        },
        "children": [
          {
            "type": "card",
            "props": {
              "variant": "elevated"
            },
            "children": [
              {
                "type": "vstack",
                "props": {
                  "spacing": "md",
                  "align": "center"
                },
                "children": [
                  {
                    "type": "text",
                    "props": {
                      "variant": "title",
                      "children": "👤"
                    }
                  },
                  {
                    "type": "text",
                    "props": {
                      "variant": "subtitle",
                      "children": "{{user.displayName}}"
                    }
                  },
                  {
                    "type": "text",
                    "props": {
                      "variant": "caption",
                      "children": "{{user.email}}"
                    }
                  },
                  {
                    "type": "divider",
                    "props": {}
                  },
                  {
                    "type": "hstack",
                    "props": {
                      "spacing": "lg"
                    },
                    "children": [
                      {
                        "type": "vstack",
                        "props": {
                          "spacing": "xs",
                          "align": "center"
                        },
                        "children": [
                          {
                            "type": "text",
                            "props": {
                              "variant": "title",
                              "children": "{{stats.posts}}"
                            }
                          },
                          {
                            "type": "text",
                            "props": {
                              "variant": "caption",
                              "children": "Posts"
                            }
                          }
                        ]
                      },
                      {
                        "type": "vstack",
                        "props": {
                          "spacing": "xs",
                          "align": "center"
                        },
                        "children": [
                          {
                            "type": "text",
                            "props": {
                              "variant": "title",
                              "children": "{{stats.followers}}"
                            }
                          },
                          {
                            "type": "text",
                            "props": {
                              "variant": "caption",
                              "children": "Followers"
                            }
                          }
                        ]
                      },
                      {
                        "type": "vstack",
                        "props": {
                          "spacing": "xs",
                          "align": "center"
                        },
                        "children": [
                          {
                            "type": "text",
                            "props": {
                              "variant": "title",
                              "children": "{{stats.following}}"
                            }
                          },
                          {
                            "type": "text",
                            "props": {
                              "variant": "caption",
                              "children": "Following"
                            }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "button",
            "props": {
              "label": "Edit Profile",
              "variant": "outline",
              "action": {
                "type": "navigate",
                "route": "profile/edit"
              }
            }
          },
          {
            "type": "button",
            "props": {
              "label": "Sign Out",
              "variant": "ghost",
              "action": {
                "type": "auth",
                "method": "signOut"
              }
            }
          }
        ]
      }
    ]
  }
}
