{
  "expo": {
    "name": "RN SDUI Toolkit Demo",
    "slug": "rn-sdui-toolkit-demo",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rntoolkit.demo"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366F1"
      },
      "package": "com.rntoolkit.demo"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "rntoolkit"
  }
}
