{
  "name": "rn-toolkit",
  "version": "0.1.0",
  "private": true,
  "description": "Free React Native toolkit: theming, primitives, i18n, performance monitoring, and testing utilities",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules",
    "versions": "npm ls --depth=0 --workspaces",
    "publish:all": "npm publish -w @astacinco/rn-theming --access public && npm publish -w @astacinco/rn-primitives --access public && npm publish -w @astacinco/rn-i18n --access public && npm publish -w @astacinco/rn-performance --access public && npm publish -w @astacinco/rn-testing --access public"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/react": "~19.1.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {}
}
